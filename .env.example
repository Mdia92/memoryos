# ── Qwen / Alibaba Cloud Model Studio ─────────────────────────────
# Get your key at https://modelstudio.console.alibabacloud.com/
DASHSCOPE_API_KEY=sk-your-key-here
# International endpoint (Singapore). Use dashscope.aliyuncs.com for CN accounts.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PRIMARY_MODEL=qwen-plus
QWEN_FALLBACK_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v3

# ── Database ───────────────────────────────────────────────────────
# Local dev (docker-compose):
DATABASE_URL=postgresql+asyncpg://memoryos:memoryos@localhost:5433/memoryos
# Alibaba Cloud production (ApsaraDB RDS for PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<rds-endpoint>:5432/memoryos

# ── App ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
# Frontend → backend base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
